    %% Entry flow
    Main --> StashPlugin
    StashPlugin --> PluginConfig
    PluginConfig --> Defaults
    PluginConfig --> Legacy

    %% Config relationships
    PluginConfig --> LLMProviderConfig
    PluginConfig --> EmbeddingSettings
    PluginConfig --> RecommendationSettings

    %% LLM flow
    LLMProviderConfig --> LLMRegistry
    LLMRegistry --> OllamaProvider
    LLMRegistry --> OpenRouterProvider
    LLMRegistry --> AnthropicProvider
    LLMRegistry --> OpenAIProvider
    ModelCaps --> LLMRegistry

    %% Embedding flow
    EmbeddingSettings --> EmbedRegistry
    EmbedRegistry --> OpenCLIP
    OpenCLIP --> EmbedStorage
    EmbedStorage --> FrameSearch

    %% Recommendation flow
    RecEngine --> Engagement
    RecEngine --> Profile
    RecEngine --> Clusters
    RecEngine --> EmbedStorage

    %% Task dispatch
    StashPlugin --> Tasks
    SceneVision --> LLMRegistry
    SceneVision --> Tools
    EmbedScenes --> EmbedRegistry
    RecTask --> RecEngine
    ChatTask --> LLMRegistry
    FrameAnalysis --> LLMRegistry

    %% Tools
    DatabaseTool --> StashDB
    EmbeddingsTool --> EmbedStorage
    VisionTool --> LLMRegistry

    %% Data layer
    Aggregators --> StashDB
    EmbedStorage --> PluginDB

    %% Frontend
    Frontend --> Main

    %% Exception hierarchy
    StashCopilotError --> LLMError
    LLMError --> VisionError
    StashCopilotError --> EmbeddingError
    StashCopilotError --> StorageError
    StashCopilotError --> TaskError

